{
  "$schema": "zed://schemas/settings",
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "autosave": "off",
  "show_wrap_guides": true,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": ".SystemUIFont",
  "buffer_font_size": 13.0,
  "ui_font_size": 13.0,
  "agent_ui_font_size": 13.0,
  "agent_buffer_font_size": 13.0,
  "colorize_brackets": true,
  "vertical_scroll_margin": 400.0,
  "notification_panel": {
    "dock": "left",
    "button": false,
    "default_width": 340
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 340
  },
  "project_panel": {
    "dock": "right",
    "default_width": 340
  },
  "collaboration_panel": {
    "dock": "left",
    "default_width": 340
  },
  "git_panel": {
    "default_width": 340,
    "status_style": "label_color",
    "button": true,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "dock": "right"
  },
  "auto_install_extensions": {
    "toml": true,
    "dockerfile": true,
    "git-firefly": true,
    "terraform": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "preview_tabs": {
    "enabled": false,
    "enable_preview_from_file_finder": false
  },
  "file_types": {
    "markdown": ["*.md"],
    "json": [".parcelrc"],
    "yaml": ["*.yml"],
    "dotenv": [".env*"],
    "html": ["*.tpl"],
    "sql-nootebook": ["*.sql-notebook"],
    "python": ["*.py"],
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values/*.yaml",
      "**/values*.yaml"
    ],
    "GitHub Actions": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml"
    ]
  },
  "show_whitespaces": "all",
  "indent_guides": {
    "enabled": false
  },
  "preferred_line_length": 120,
  "soft_wrap": "prefer_line",
  "tab_size": 2,
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "VSCode Icons for Zed (Dark)"
  },
  "show_edit_predictions": true,
  "theme": {
    "mode": "dark",
    "dark": "Tokyo Night",
    "light": "One Dark"
  },
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "language_servers": ["!biome", "!deno", "..."],
  "lsp": {
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": ["deno.json", "deno.jsonc"],
              "url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json"
            },
            {
              "fileMatch": ["package.json"],
              "url": "http://json.schemastore.org/package"
            }
          ]
        }
      }
    }
  }
}
