# EDITOR/VISUAL are set in dot_zshenv.tmpl (smart-editor: display-aware).

{{- if eq .chezmoi.os "darwin" }}
[ -d "$(brew --prefix trash 2>/dev/null)/bin" ] && export PATH="$(brew --prefix trash)/bin:$PATH"
{{- end }}

zstyle ':completion:*' menu select
# zstyle ':completion:*' menu select=0 yes search
zstyle ':completion:*' group-name ''
zstyle ':completion:::::' completer _expand _complete _ignored _approximate # enable approximate matches for completion
zstyle ':completion:*' format '%F{blue}%B -- %d -- %b%f'
zstyle ':completion:*' matcher-list '' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]}' '+l:|?=** r:|?=**'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*:descriptions' format "$fg[yellow]%B--- %d%b"
zstyle ':completion:*:messages' format '%d'
zstyle ':completion:*:warnings' format "$fg[red]No matches for:$reset_color %d"
zstyle ':completion:*:corrections' format '%B%d (errors: %e)%b'

# Initialize editing command line
autoload -U edit-command-line && zle -N edit-command-line

zmodload zsh/complist

# Time to wait for additional characters in a sequence
KEYTIMEOUT=1 # corresponds to 10ms

# Fixes [home|end] keys
bindkey "^[[7~" beginning-of-line
bindkey "^[[8~" end-of-line

# Cmd+Shift+Left/Right → line start/end
bindkey "^[[1;10D" beginning-of-line
bindkey "^[[1;10C" end-of-line

# Option+Left/Right → word navigation
bindkey "^[b"    backward-word   # Zed / emacs encoding
bindkey "^[f"    forward-word    # Zed / emacs encoding
bindkey "^[^[[D" backward-word   # macOS Terminal.app encoding
bindkey "^[^[[C" forward-word    # macOS Terminal.app encoding
bindkey "^[[1;3D" backward-word  # xterm / WezTerm encoding
bindkey "^[[1;3C" forward-word   # xterm / WezTerm encoding

# Shift+Arrow — bind explicitly to prevent fallback deletion behavior
bindkey "^[[1;2D" backward-char
bindkey "^[[1;2C" forward-char
bindkey "^[[1;2A" up-line-or-history
bindkey "^[[1;2B" down-line-or-history

# delete key
bindkey "^[[3~" delete-char
bindkey "^[3;5~" delete-char
bindkey "^[[3;5~" delete-word

# zsh undo/redo
bindkey '^[z' undo
bindkey '^[Z' redo

# Shift tab for menu-complete
bindkey -M menuselect '^[[Z' reverse-menu-complete

export SKIM_DEFAULT_OPTIONS="--ansi --cycle --border --height=15"
