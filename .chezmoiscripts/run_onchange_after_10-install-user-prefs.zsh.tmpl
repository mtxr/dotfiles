#!/usr/bin/env bash
set -e

# Re-runs when this rendered script changes (tools/flags/flavor).
# Installs mise tools declared in ~/.config/mise/config.toml (already applied).
#
# TOOLS_SNAPSHOT (forces re-run when desired set changes):
# flavor={{ .preferences.installFlavor }}
# node={{ .install.node }} rust={{ .install.rust }} zig={{ .install.zig }}
# golang={{ .install.golang }} ruby={{ .install.ruby }} reactnative={{ .install.reactnative }}
# gcloud={{ .install.gcloud }}
# light_clis=bat,fd,ripgrep,delta,diffnav,starship,just,git-lfs,rust-parallel,atuin,sk,topgrade,uv,python
# brew_light=mise,antidote,eza
# full_clis=jq,gh,dust,procs,grex,hwatch,glow

{{ if eq .chezmoi.os "darwin" }}
if [ -d /opt/homebrew ]; then
  export HOMEBREW_PREFIX="/opt/homebrew"
elif [ -d /usr/local/homebrew ]; then
  export HOMEBREW_PREFIX="/usr/local/homebrew"
fi
{{ end }}
{{ if eq .chezmoi.os "linux" }}
if [ -d /home/linuxbrew/.linuxbrew ]; then
  export HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
elif [ -d $HOME/.linuxbrew ]; then
  export HOMEBREW_PREFIX="$HOME/.linuxbrew"
fi
{{ end }}

if [ -z "${HOMEBREW_PREFIX:-}" ] || [ ! -x "${HOMEBREW_PREFIX}/bin/brew" ]; then
  echo "❌ Homebrew not found; run system install first."
  exit 1
fi

eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"

if ! command -v mise &>/dev/null; then
  echo "❌ mise not found on PATH after brew shellenv. Is the mise formula installed?"
  exit 1
fi

# Activate mise so `mise install` and later gem/etc steps see the right tools.
eval "$(mise activate bash --shims)"
eval "$(mise activate bash)"

echo "🔄 Installing mise tools from ~/.config/mise/config.toml ..."
mise install -y
echo "✅ mise tools installed."

{{- if .install.gcloud }}
if ! brew list --cask gcloud-cli &>/dev/null; then
  echo "🔄 Installing gcloud-cli cask..."
  brew install --cask gcloud-cli
else
  echo "✅ gcloud-cli already installed."
fi
{{- end }}

{{- if .install.reactnative }}
## TODO REVIEW THIS
echo "🔄 Installing React Native Ruby gems (ffi, cocoapods)..."
mise exec ruby -- sudo gem install ffi
mise exec ruby -- sudo gem install cocoapods
# brew tap facebook/fb
# brew install idb-companion
# pip3 install fb-idb --break-system-packages
# brew install ios-deploy
{{- end }}
