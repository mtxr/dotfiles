#!/bin/bash
set -e

# Enable debug mode if DEBUG is set to 1
if [[ "${DEBUG:-0}" == "1" ]]; then
  set -x
fi

# Make sure Homebrew-installed gh is reachable on a fresh setup.
for prefix in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew "$HOME/.linuxbrew"; do
  [ -d "$prefix/bin" ] && export PATH="$prefix/bin:$PATH"
done

if ! command -v gh &>/dev/null; then
  echo "ℹ️  gh not installed; skipping gh extensions."
  exit 0
fi

# gh extensions to keep installed. Editing this list re-triggers the script
# (run_onchange hashes the rendered content).
GH_EXTENSIONS=(
  dlvhdr/gh-dash
  dlvhdr/gh-enhance
)

for ext in "${GH_EXTENSIONS[@]}"; do
  echo "🔄 Ensuring gh extension $ext..."
  # Attempt the install and classify the result. `gh` exits non-zero both when
  # the extension is already installed and when another extension already
  # provides the same command — neither should abort the whole apply.
  if out="$(gh extension install "$ext" 2>&1)"; then
    echo "✅ Installed $ext"
  elif echo "$out" | grep -qiE "already installed|already an installed extension"; then
    echo "✅ $ext already present (or its command is provided by another extension); skipping"
  else
    echo "⚠️  Could not install $ext (continuing):"
    echo "$out" | sed 's/^/    /'
  fi
done

echo "✅ gh extensions ready!"
exit 0
