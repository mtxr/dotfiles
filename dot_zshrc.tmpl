export PATH="$HOME/.local/bin:$PATH"
export PATH="$GOPATH/bin:$PATH"
export PATH="/usr/local/sbin:$PATH"
export PATH="/usr/local/bin:$PATH"
export PATH="/sbin:$PATH"
export PATH=$GEM_HOME/bin:$PATH
export GPG_TTY=$(tty)

bindkey -e

{{- if eq .chezmoi.os "linux" }}
if [ -d /usr/local/cuda ]; then
  export PATH="/usr/local/cuda/bin:$PATH"
  export LD_LIBRARY_PATH="/usr/local/cuda/lib64:$LD_LIBRARY_PATH"
fi
{{- end }}

{{ if eq .chezmoi.os "darwin" }}
if [ -d /opt/homebrew ]; then
  export HOMEBREW_PREFIX="/opt/homebrew"
elif [ -d /usr/local/homebrew ]; then
  export HOMEBREW_PREFIX="/usr/local/homebrew"
fi
{{ end }}
{{ if eq .chezmoi.os "linux" }}
if [ -d /home/linuxbrew/.linuxbrew ]; then
  export HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
elif [ -d $HOME/.linuxbrew ]; then
  export HOMEBREW_PREFIX="$HOME/.linuxbrew"
fi
{{ end }}

eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"

if [ -f "$HOMEBREW_PREFIX/share/google-cloud-sdk/path.zsh.inc" ]; then
  source "$HOMEBREW_PREFIX/share/google-cloud-sdk/path.zsh.inc"
  source "$HOMEBREW_PREFIX/share/google-cloud-sdk/completion.zsh.inc"
fi

# mise owns language toolchains + most CLIs (see ~/.config/mise/config.toml).
# Activate after brew so mise shims/bin take precedence over leftover brew formulas.
eval "$(mise activate zsh --shims)"
eval "$(mise activate zsh)"

{{- if .install.node }}
# pnpm global packages live under PNPM_HOME (not managed by mise).
# Required for `pnpm add -g` / topgrade's `pnpm update -g`.
# Do not run `pnpm setup` — it appends to ~/.zshrc and fights chezmoi.
{{ if eq .chezmoi.os "darwin" -}}
export PNPM_HOME="$HOME/Library/pnpm"
{{ else -}}
export PNPM_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/pnpm"
{{ end -}}
# Append (do not prepend) so mise's pnpm stays ahead of any global @pnpm/exe.
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PATH:$PNPM_HOME/bin" ;;
esac
{{- end }}

export PKG_CONFIG_PATH="$HOMEBREW_PREFIX/lib/pkgconfig:$PKG_CONFIG_PATH"
{{- if eq .chezmoi.os "linux" }}
export PKG_CONFIG_PATH="/usr/lib/x86_64-linux-gnu/ kgconfig:/usr/share/pkgconfig:/usr/lib/pkgconfig:$PKG_CONFIG_PATH"
{{- end }}
{{- if .install.android }}
export PATH=$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/emulator:$ANDROID_HOME/tools:$ANDROID_HOME/tools/bin:$ANDROID_HOME/platform-tools:$PATH
{{- end }}

typeset -U path

# Aliases
. $HOME/.zsh/aliases.zsh

# Functions
. $HOME/.zsh/functions.zsh

# Bootstrap
. $HOME/.zsh/bootstrap.zsh

{{ if eq .chezmoi.os "darwin" }}
[ -f "${HOME}/.iterm2_shell_integration.zsh" ] && . "${HOME}/.iterm2_shell_integration.zsh"
{{ end }}

# External plugins (initialized after)
. $HOME/.zsh/plugins_after.zsh

# Need a tweak in arch for home and end keys to work properly
# (as well as insert, delete, pageup, pagedown, perhaps others...)
# https://wiki.archlinux.org/index.php/Home_and_End_keys_not_working#Zsh
bindkey "^[[2~" overwrite-mode # Ins
bindkey "^[[3~" delete-char # Del

# but.... home and end key escape sequences
# are DIFFERENT depending on whether I'm in a tmux session or not!
# To determine if tmux is running, examine values of $TERM and $TMUX.
if [[ "$TERM" =~ "screen" ]] && [ -n "$TMUX" ]; then
  bindkey "^[[1~" beginning-of-line
  bindkey "^[[4~" end-of-line
else
  # Assign these keys if tmux is NOT being used:
  bindkey "^[[H" beginning-of-line
  bindkey "^[[F" end-of-line
fi


eval "$(starship init zsh)"
command -v atuin &>/dev/null && eval "$(atuin init zsh --disable-up-arrow)"

command -v dircolors &>/dev/null && eval `dircolors ~/.dircolors/theme`
command -v gdircolors &>/dev/null && eval `gdircolors ~/.dircolors/theme`

# Allow local customizations loading ~/.zsh-load folder
if [ -d "$HOME/.zsh-load" ];then
  # (.ND) Qualifiers:
  # . = regular files only (no directories)
  # N = nullglob (don't error if no files found)
  # D = dotglob (include hidden files)
  for TO_LOAD in $HOME/.zsh-load/***/*.sh(.ND); do
    source "$TO_LOAD"
  done
  unset TO_LOAD
fi
