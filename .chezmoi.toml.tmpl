{{- $nodeOptions := "" -}}

{{- $name := promptStringOnce . "name" "Enter your full name" -}}
{{- $email := promptStringOnce . "email" "Enter your email address" -}}

{{- $node := promptBoolOnce . "install.node" "Install Node.js development tools?" false -}}
{{- $rust := promptBoolOnce . "install.rust" "Install Rust development tools?" false -}}
{{- $zig := promptBoolOnce . "install.zig" "Install Zig development tools?" false -}}
{{- $ruby := promptBoolOnce . "install.ruby" "Install Ruby development tools?" false -}}
{{- $golang := promptBoolOnce . "install.golang" "Install Golang development tools?" false -}}
{{- $reactnative := promptBoolOnce . "install.reactnative" "Install React Native development tools?" false -}}
{{- $gcloud := promptBoolOnce . "install.gcloud" "Install gcloud-sdk development tools?" false -}}
{{- $android := promptBoolOnce . "install.android" "Setup Android SDK Paths?" false -}}
{{- $ruby := or $ruby $reactnative }}
{{- $editorChoices := list "code" "cursor" "surf" "zed" -}}
{{- $preferredEditor := promptChoiceOnce . "preferences.editor" "Select your preferred editor" $editorChoices "zed" -}}

{{- $installFlavor := list "light" "full" -}}
{{- $installFlavor := promptChoiceOnce . "preferences.installFlavor" "Select your preferred install flavor" $installFlavor "light" -}}

{{- if $node }}
{{- $nodeOptions := promptStringOnce . "preferences.nodeOptions" "Enter any Node.js options" "" -}}
{{- end }}

{{- $preferredMergeEditor := "surf" -}}
{{- if ne $preferredEditor "zed" -}}
{{- $preferredMergeEditor := $preferredEditor -}}
{{- end -}}

[data]
  name = {{ $name | quote }}
  email = {{ $email | quote }}
[data.preferences]
  editor = {{ $preferredEditor | quote }}
  mergeEditor = {{ $preferredMergeEditor | quote }}
  nodeOptions = {{ $nodeOptions | quote }}
  installFlavor = {{ $installFlavor | quote }}

[data.install]
  android = {{ $android }}
  node = {{ $node }}
  rust = {{ $rust }}
  zig  = {{ $zig }}
  ruby = {{ $ruby }}
  golang = {{ $golang }}
  reactnative = {{ $reactnative }}
  gcloud = {{ $gcloud }}

# Package lists live in .chezmoidata/packages_*.yaml so they can be edited
# without re-running `chezmoi init`. The install script merges `base` with the
# OS-specific namespace (darwin/linux).

# chezmoi options
[git]
  autoCommit = false
  autoPush = false
  autoAdd = true

[template]
  options = ["missingkey=error"]

[edit]
  command = "smart-editor"

[diff]
pager = "diffnav"

# smart-editor picks the GUI editor when a display exists, else flow (terminal).
# The .Destination/.Source/.Target placeholders are emitted literally (via %q)
# so chezmoi re-templates them at merge time, not at init time.
[merge]
  command = "smart-editor"
  args = [
      "--chezmoi-merge",
      {{ printf "%q, %q, %q" "{{ .Destination }}" "{{ .Source }}" "{{ .Target }}" }},
  ]
